          "name": "Staff",
          "item": [
            {
              "name": "Create Staff",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status code is 201 Created\", function () {",
                      "    pm.response.to.have.status(201);",
                      "});",
                      "",
                      "pm.test(\"Response body has required properties\", function () {",
                      "    const jsonData = pm.response.json();",
                      "    pm.expect(jsonData).to.have.property('id');",
                      "    pm.expect(jsonData).to.have.property('Nama', 'Budi Staff');",
                      "    pm.collectionVariables.set(\"staffId\", jsonData.id);",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"Nama\": \"Budi Staff\",\n    \"Gender\": \"L\",\n    \"NIK\": \"3301010101950003\",\n    \"No_WhatsApp\": \"081234567899\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{baseUrl}}/customers/staff",
